{
  "version": "1.0",
  "description": "Radiotherapy workflow case lifecycle — statuses, transitions, and compensations. Single source of truth for diagram generation.",

  "phases": [
    { "id": "SIM",  "number": 1, "name": "Intake & Simulation",             "codeRange": "SIM-001 – SIM-005"   },
    { "id": "IMG",  "number": 2, "name": "Image Acquisition & Forwarding",  "codeRange": "IMG-001 – IMG-003"   },
    { "id": "CON",  "number": 3, "name": "Contouring",                      "codeRange": "CON-001 – CON-005"   },
    { "id": "REV",  "number": 4, "name": "Contour Review",                  "codeRange": "REV-001 – REV-004"   },
    { "id": "PLN",  "number": 5, "name": "Treatment Planning",              "codeRange": "PLN-001 – PLN-006"   },
    { "id": "RX",   "number": 6, "name": "Re-review & Prescription",        "codeRange": "RX-001 – RX-007"    },
    { "id": "QA",   "number": 7, "name": "Plan QA & Double-check",          "codeRange": "QA-001 – QA-008"    },
    { "id": "TRT",  "number": 8, "name": "Scheduling, Order & Treatment",   "codeRange": "TRT-001 – TRT-012"  },
    { "id": "POST", "number": 9, "name": "Post-treatment & Archiving",      "codeRange": "POST-001 – POST-003" }
  ],

  "statuses": [
    { "name": "Draft",                      "value": 0,   "phase": "SIM"  },
    { "name": "Submitted",                  "value": 10,  "phase": "SIM"  },
    { "name": "SimScheduled",               "value": 20,  "phase": "SIM"  },
    { "name": "SimInProgress",              "value": 30,  "phase": "SIM"  },
    { "name": "SimCompleted",               "value": 40,  "phase": "SIM"  },
    { "name": "ImageStored",                "value": 50,  "phase": "IMG"  },
    { "name": "ImageForwarding",            "value": 60,  "phase": "IMG"  },
    { "name": "ContouringInProgress",       "value": 70,  "phase": "CON"  },
    { "name": "ContourReworkRequired",      "value": 110, "phase": "CON"  },
    { "name": "ContoursReady",              "value": 80,  "phase": "REV"  },
    { "name": "ContoursUnderReview",        "value": 90,  "phase": "REV"  },
    { "name": "ContoursRejected",           "value": 100, "phase": "REV"  },
    { "name": "PlanningPending",            "value": 120, "phase": "PLN"  },
    { "name": "PlanningAssigned",           "value": 130, "phase": "PLN"  },
    { "name": "PlanningInProgress",         "value": 140, "phase": "PLN"  },
    { "name": "PlanReady",                  "value": 150, "phase": "PLN"  },
    { "name": "PlanUnderReview",            "value": 160, "phase": "PLN"  },
    { "name": "PlanReviewed",               "value": 170, "phase": "PLN"  },
    { "name": "PlanReReviewOptional",       "value": 180, "phase": "RX"   },
    { "name": "PrescriptionGenerating",     "value": 190, "phase": "RX"   },
    { "name": "PrescriptionReady",          "value": 200, "phase": "RX"   },
    { "name": "PrescriptionSyncFailed",     "value": 210, "phase": "RX"   },
    { "name": "PlanQAInProgress",           "value": 220, "phase": "QA"   },
    { "name": "PlanQAApproved",             "value": 230, "phase": "QA"   },
    { "name": "PlanQAFailed",               "value": 240, "phase": "QA"   },
    { "name": "PlanDoubleCheckOptional",    "value": 250, "phase": "QA"   },
    { "name": "ReadyForScheduling",         "value": 260, "phase": "QA"   },
    { "name": "SchedulingInProgress",       "value": 270, "phase": "TRT"  },
    { "name": "Scheduled",                  "value": 280, "phase": "TRT"  },
    { "name": "OrderPending",               "value": 290, "phase": "TRT"  },
    { "name": "OrderSubmitted",             "value": 300, "phase": "TRT"  },
    { "name": "QueuePending",               "value": 310, "phase": "TRT"  },
    { "name": "Treating",                   "value": 320, "phase": "TRT"  },
    { "name": "TreatmentPaused",            "value": 330, "phase": "TRT"  },
    { "name": "TreatmentInterrupted",       "value": 340, "phase": "TRT"  },
    { "name": "TreatmentCompleted",         "value": 350, "phase": "TRT"  },
    { "name": "PostTreatmentReviewPending", "value": 360, "phase": "POST" },
    { "name": "PostTreatmentReviewed",      "value": 370, "phase": "POST" },
    { "name": "Archived",                   "value": 380, "phase": "POST" },
    { "name": "Cancelled",                  "value": 390, "phase": "TERM" }
  ],

  "transitions": [

    {
      "code": "SIM-001",
      "phase": "SIM",
      "description": "Doctor submits the simulation request, creating the case workload",
      "fromStatuses": ["Draft"],
      "toStatus": "Submitted",
      "triggerName": "SubmitSimulationRequest",
      "triggerType": "User",
      "requiredRole": "Doctor",
      "gateChecks": ["SimulationRequestFormValid"],
      "successActions": ["SaveForm", "Audit", "RecordTransitionHistory"],
      "failureActions": ["RejectTransition"],
      "workItemsToCreate": ["SimulationSchedule", "SimulationRecord"],
      "configSlot": null
    },
    {
      "code": "SIM-002",
      "phase": "SIM",
      "description": "Simulation technologist or scheduler books the CT simulation appointment",
      "fromStatuses": ["Submitted"],
      "toStatus": "SimScheduled",
      "triggerName": "ScheduleSimulation",
      "triggerType": "User",
      "requiredRole": "SimTech/Scheduler",
      "gateChecks": ["CaseActiveNotCancelled"],
      "successActions": ["SaveScheduleInfo"],
      "failureActions": ["StayInSubmitted"],
      "workItemsToCreate": ["SimulationSchedule"],
      "configSlot": null
    },
    {
      "code": "SIM-003",
      "phase": "SIM",
      "description": "Simulation technologist marks that the CT simulation scan has begun",
      "fromStatuses": ["SimScheduled"],
      "toStatus": "SimInProgress",
      "triggerName": "StartSimulation",
      "triggerType": "User",
      "requiredRole": "SimTech",
      "gateChecks": ["SimulationScheduleExists"],
      "successActions": ["Audit"],
      "failureActions": ["StayInSimScheduled"],
      "workItemsToCreate": [],
      "configSlot": null
    },
    {
      "code": "SIM-004",
      "phase": "SIM",
      "description": "Simulation technologist submits the CT simulation record, completing the phase",
      "fromStatuses": ["SimInProgress"],
      "toStatus": "SimCompleted",
      "triggerName": "SubmitSimulationRecord",
      "triggerType": "User",
      "requiredRole": "SimTech",
      "gateChecks": ["SimulationRecordFormValid"],
      "successActions": ["SaveForm", "CompleteSimulationRecord"],
      "failureActions": ["StayInSimInProgress"],
      "workItemsToCreate": ["ImageValidation"],
      "configSlot": null
    },
    {
      "code": "SIM-005",
      "phase": "SIM",
      "description": "Doctor or admin cancels the case before treatment has started",
      "fromStatuses": ["Submitted", "SimScheduled", "SimInProgress"],
      "toStatus": "Cancelled",
      "triggerName": "CancelCase",
      "triggerType": "User",
      "requiredRole": "Doctor/Admin",
      "gateChecks": ["TreatmentNotStarted"],
      "successActions": ["SaveCancellationForm", "CloseOpenTasks"],
      "failureActions": ["RejectCancellation"],
      "workItemsToCreate": [],
      "configSlot": "S8ExceptionHandlingPolicy"
    },

    {
      "code": "IMG-001",
      "phase": "IMG",
      "description": "External imaging system notifies that CT images have been stored in DICOM repository",
      "fromStatuses": ["SimCompleted"],
      "toStatus": "ImageStored",
      "triggerName": "ReceiveCtImageStoredEvent",
      "triggerType": "ExternalEvent",
      "requiredRole": null,
      "gateChecks": ["CaseResolvedByCorrelationKey", "ImageRefsValid"],
      "successActions": ["SaveExternalEvent", "SaveImageRefs", "SaveIntegrationReference"],
      "failureActions": ["MarkEventFailed"],
      "workItemsToCreate": ["ImageValidation"],
      "configSlot": null
    },
    {
      "code": "IMG-002",
      "phase": "IMG",
      "description": "System automatically forwards stored CT images to the contouring tool",
      "fromStatuses": ["ImageStored"],
      "toStatus": "ImageForwarding",
      "triggerName": "StartImageForwarding",
      "triggerType": "System",
      "requiredRole": null,
      "gateChecks": ["ImageAccessible"],
      "successActions": ["CreateOutboxSendImagesToContourTool"],
      "failureActions": ["RetryOutbox"],
      "workItemsToCreate": ["ImageForwardToContourTool"],
      "configSlot": "S1ContouringStrategy"
    },
    {
      "code": "IMG-003",
      "phase": "IMG",
      "description": "Contouring tool acknowledges receipt of the images, initiating the contouring job",
      "fromStatuses": ["ImageForwarding"],
      "toStatus": "ContouringInProgress",
      "triggerName": "ContourToolAccepted",
      "triggerType": "ExternalEvent",
      "requiredRole": null,
      "gateChecks": ["ExternalAcceptOrDeliveryConfirmed"],
      "successActions": ["SaveExternalJobRef"],
      "failureActions": ["ManualResend"],
      "workItemsToCreate": ["AutoContourMonitor"],
      "configSlot": "S1ContouringStrategy"
    },

    {
      "code": "CON-001",
      "phase": "CON",
      "description": "Contouring tool reports incremental progress; idempotent self-transition",
      "fromStatuses": ["ContouringInProgress"],
      "toStatus": "ContouringInProgress",
      "triggerName": "AutoContourProgressUpdated",
      "triggerType": "ExternalEvent",
      "requiredRole": null,
      "gateChecks": ["EventIdempotent"],
      "successActions": ["UpdateProgress", "Audit"],
      "failureActions": ["IgnoreDuplicate"],
      "workItemsToCreate": ["AutoContourMonitor"],
      "configSlot": null
    },
    {
      "code": "CON-002",
      "phase": "CON",
      "description": "Auto-contouring completed; RTStruct references saved and review tasks created",
      "fromStatuses": ["ContouringInProgress"],
      "toStatus": "ContoursReady",
      "triggerName": "AutoContourCompleted",
      "triggerType": "ExternalEvent",
      "requiredRole": null,
      "gateChecks": ["ContourResultRefsValid"],
      "successActions": ["SaveRTStructRefs", "CloseAutoContourMonitor"],
      "failureActions": ["CreateContourRework"],
      "workItemsToCreate": ["ContourReview", "ContourSecondReview"],
      "configSlot": "S2ContourReviewPolicy"
    },
    {
      "code": "CON-003",
      "phase": "CON",
      "description": "Auto-contouring failed; case moves to rework-required state for manual resolution",
      "fromStatuses": ["ContouringInProgress"],
      "toStatus": "ContourReworkRequired",
      "triggerName": "AutoContourFailed",
      "triggerType": "ExternalEvent",
      "requiredRole": null,
      "gateChecks": ["EventValid"],
      "successActions": ["AuditFailure"],
      "failureActions": ["RetryIfConfigured"],
      "workItemsToCreate": ["ManualContouring"],
      "configSlot": "S8ExceptionHandlingPolicy"
    },
    {
      "code": "CON-004",
      "phase": "CON",
      "description": "Doctor or system restarts the auto-contouring job after a rework decision",
      "fromStatuses": ["ContourReworkRequired"],
      "toStatus": "ContouringInProgress",
      "triggerName": "RestartContouring",
      "triggerType": "User",
      "requiredRole": "Doctor/System",
      "gateChecks": ["RetryAllowed"],
      "successActions": ["CreateOutboxRestartContouring"],
      "failureActions": ["StayInContourRework"],
      "workItemsToCreate": ["AutoContourMonitor"],
      "configSlot": "S1ContouringStrategy"
    },
    {
      "code": "CON-005",
      "phase": "CON",
      "description": "Doctor or third-party operator submits manual contour results, bypassing auto-contouring",
      "fromStatuses": ["ContourReworkRequired"],
      "toStatus": "ContoursReady",
      "triggerName": "SubmitManualContourResult",
      "triggerType": "User",
      "requiredRole": "Doctor/ThirdPartyOperator",
      "gateChecks": ["ManualContourPayloadValid"],
      "successActions": ["SaveContourRefs"],
      "failureActions": ["StayInContourRework"],
      "workItemsToCreate": ["ContourReview", "ContourSecondReview"],
      "configSlot": "S2ContourReviewPolicy"
    },

    {
      "code": "REV-001",
      "phase": "REV",
      "description": "System automatically begins contour review once contours are ready",
      "fromStatuses": ["ContoursReady"],
      "toStatus": "ContoursUnderReview",
      "triggerName": "StartContourReview",
      "triggerType": "System",
      "requiredRole": null,
      "gateChecks": ["ContourResultExists"],
      "successActions": ["CreateReviewTasks"],
      "failureActions": [],
      "workItemsToCreate": ["ContourReview", "ContourSecondReview"],
      "configSlot": "S2ContourReviewPolicy"
    },
    {
      "code": "REV-002",
      "phase": "REV",
      "description": "Doctor or chief doctor approves the contours, advancing the case to planning",
      "fromStatuses": ["ContoursUnderReview"],
      "toStatus": "PlanningPending",
      "triggerName": "ApproveContours",
      "triggerType": "User",
      "requiredRole": "Doctor/ChiefDoctor",
      "gateChecks": ["MinimumApprovalsReached"],
      "successActions": ["CompleteReviewTasks"],
      "failureActions": ["RejectTransition"],
      "workItemsToCreate": ["PlanAssignment"],
      "configSlot": "S2ContourReviewPolicy"
    },
    {
      "code": "REV-003",
      "phase": "REV",
      "description": "Doctor or chief doctor rejects the contours; a rework work item is created",
      "fromStatuses": ["ContoursUnderReview"],
      "toStatus": "ContoursRejected",
      "triggerName": "RejectContours",
      "triggerType": "User",
      "requiredRole": "Doctor/ChiefDoctor",
      "gateChecks": ["RejectionReasonRequired"],
      "successActions": ["SaveReviewForm"],
      "failureActions": ["RejectTransition"],
      "workItemsToCreate": ["ContourRework"],
      "configSlot": "S2ContourReviewPolicy"
    },
    {
      "code": "REV-004",
      "phase": "REV",
      "description": "Doctor or system resubmits revised contours for another review cycle",
      "fromStatuses": ["ContoursRejected"],
      "toStatus": "ContouringInProgress",
      "triggerName": "ResubmitContours",
      "triggerType": "User",
      "requiredRole": "Doctor/System",
      "gateChecks": ["RevisedContourExists"],
      "successActions": ["ClearStaleReviewTasks"],
      "failureActions": ["StayInContoursRejected"],
      "workItemsToCreate": ["AutoContourMonitor"],
      "configSlot": "S8ExceptionHandlingPolicy"
    },

    {
      "code": "PLN-001",
      "phase": "PLN",
      "description": "Scheduler or system assigns a dosimetrist/physicist to create the treatment plan",
      "fromStatuses": ["PlanningPending"],
      "toStatus": "PlanningAssigned",
      "triggerName": "AssignPlanner",
      "triggerType": "User",
      "requiredRole": "Scheduler/System",
      "gateChecks": ["AssigneeExists"],
      "successActions": ["SavePlannerInfo"],
      "failureActions": ["StayInPlanningPending"],
      "workItemsToCreate": ["PlanDesign"],
      "configSlot": "S3PlanDispatch"
    },
    {
      "code": "PLN-002",
      "phase": "PLN",
      "description": "Dosimetrist or physicist accepts the assigned plan task and begins work",
      "fromStatuses": ["PlanningAssigned"],
      "toStatus": "PlanningInProgress",
      "triggerName": "AcceptPlanTask",
      "triggerType": "User",
      "requiredRole": "Dosimetrist/Physicist",
      "gateChecks": ["TaskAssigned"],
      "successActions": ["MarkTaskInProgress"],
      "failureActions": ["StayInPlanningAssigned"],
      "workItemsToCreate": [],
      "configSlot": "S3PlanDispatch"
    },
    {
      "code": "PLN-003",
      "phase": "PLN",
      "description": "Dosimetrist or Monaco system submits the completed treatment plan",
      "fromStatuses": ["PlanningInProgress"],
      "toStatus": "PlanReady",
      "triggerName": "SubmitPlan",
      "triggerType": "User",
      "requiredRole": "Dosimetrist/Monaco",
      "gateChecks": ["PlanPayloadValid"],
      "successActions": ["CreatePlanVersion"],
      "failureActions": ["RejectSubmit"],
      "workItemsToCreate": ["PlanEvaluation"],
      "configSlot": null
    },
    {
      "code": "PLN-004",
      "phase": "PLN",
      "description": "System or physicist initiates formal review of the submitted plan",
      "fromStatuses": ["PlanReady"],
      "toStatus": "PlanUnderReview",
      "triggerName": "StartPlanReview",
      "triggerType": "System",
      "requiredRole": null,
      "gateChecks": ["PlanVersionExists"],
      "successActions": ["CreateEvaluationTask"],
      "failureActions": [],
      "workItemsToCreate": ["PlanEvaluation"],
      "configSlot": null
    },
    {
      "code": "PLN-005",
      "phase": "PLN",
      "description": "Physicist or doctor rejects the plan, sending it back for redesign",
      "fromStatuses": ["PlanUnderReview"],
      "toStatus": "PlanningInProgress",
      "triggerName": "RejectPlan",
      "triggerType": "User",
      "requiredRole": "Physicist/Doctor",
      "gateChecks": ["RejectionReasonRequired"],
      "successActions": ["IncrementPlanVersionContext"],
      "failureActions": ["StayInPlanReview"],
      "workItemsToCreate": ["PlanDesign"],
      "configSlot": null
    },
    {
      "code": "PLN-006",
      "phase": "PLN",
      "description": "Physicist or doctor approves the plan review; optional re-review may follow depending on S4 policy",
      "fromStatuses": ["PlanUnderReview"],
      "toStatus": "PlanReviewed",
      "triggerName": "ApprovePlanReview",
      "triggerType": "User",
      "requiredRole": "Physicist/Doctor",
      "gateChecks": ["EvaluationApproved"],
      "successActions": ["Audit"],
      "failureActions": ["RejectTransition"],
      "workItemsToCreate": ["PlanReReview"],
      "configSlot": "S4PlanReReviewPolicy"
    },

    {
      "code": "RX-001",
      "phase": "RX",
      "description": "System starts an optional secondary plan review when the policy slot requires it",
      "fromStatuses": ["PlanReviewed"],
      "toStatus": "PlanReReviewOptional",
      "triggerName": "StartPlanReReview",
      "triggerType": "System",
      "requiredRole": null,
      "gateChecks": ["S4ReReviewEnabled"],
      "successActions": ["CreateReReviewTask"],
      "failureActions": ["SkipIfDisabled"],
      "workItemsToCreate": ["PlanReReview"],
      "configSlot": "S4PlanReReviewPolicy"
    },
    {
      "code": "RX-002",
      "phase": "RX",
      "description": "System initiates prescription generation when no re-review is required",
      "fromStatuses": ["PlanReviewed"],
      "toStatus": "PrescriptionGenerating",
      "triggerName": "StartPrescriptionGeneration",
      "triggerType": "System",
      "requiredRole": null,
      "gateChecks": ["NoReReviewRequired"],
      "successActions": ["CreateOutboxGeneratePrescription"],
      "failureActions": ["RetryOrManualSync"],
      "workItemsToCreate": ["PrescriptionSync"],
      "configSlot": "S4PlanReReviewPolicy"
    },
    {
      "code": "RX-003",
      "phase": "RX",
      "description": "Chief doctor or senior physicist approves the re-review, triggering prescription generation",
      "fromStatuses": ["PlanReReviewOptional"],
      "toStatus": "PrescriptionGenerating",
      "triggerName": "ApprovePlanReReview",
      "triggerType": "User",
      "requiredRole": "ChiefDoctor/SeniorPhysicist",
      "gateChecks": ["ReReviewApproved"],
      "successActions": ["CreateOutboxGeneratePrescription"],
      "failureActions": ["RejectTransition"],
      "workItemsToCreate": ["PrescriptionSync"],
      "configSlot": "S4PlanReReviewPolicy"
    },
    {
      "code": "RX-004",
      "phase": "RX",
      "description": "Chief doctor or senior physicist rejects the re-review, sending the plan back for rework",
      "fromStatuses": ["PlanReReviewOptional"],
      "toStatus": "PlanningInProgress",
      "triggerName": "RejectPlanReReview",
      "triggerType": "User",
      "requiredRole": "ChiefDoctor/SeniorPhysicist",
      "gateChecks": ["ReasonRequired"],
      "successActions": ["PlanBackToRework"],
      "failureActions": ["StayInReReview"],
      "workItemsToCreate": ["PlanDesign"],
      "configSlot": "S4PlanReReviewPolicy"
    },
    {
      "code": "RX-005",
      "phase": "RX",
      "description": "External system notifies that prescription generation has succeeded",
      "fromStatuses": ["PrescriptionGenerating"],
      "toStatus": "PrescriptionReady",
      "triggerName": "PrescriptionGenerated",
      "triggerType": "ExternalEvent",
      "requiredRole": null,
      "gateChecks": ["PrescriptionReferenceValid"],
      "successActions": ["SaveIntegrationReference"],
      "failureActions": ["RetryOrManualSync"],
      "workItemsToCreate": ["PlanQA"],
      "configSlot": null
    },
    {
      "code": "RX-006",
      "phase": "RX",
      "description": "External system reports that prescription synchronisation failed",
      "fromStatuses": ["PrescriptionGenerating"],
      "toStatus": "PrescriptionSyncFailed",
      "triggerName": "PrescriptionSyncFailed",
      "triggerType": "ExternalEvent",
      "requiredRole": null,
      "gateChecks": ["FailureEventValid"],
      "successActions": ["AuditFailure"],
      "failureActions": ["RetryLater"],
      "workItemsToCreate": ["PrescriptionSync"],
      "configSlot": "S8ExceptionHandlingPolicy"
    },
    {
      "code": "RX-007",
      "phase": "RX",
      "description": "Physicist or system retries the failed prescription synchronisation",
      "fromStatuses": ["PrescriptionSyncFailed"],
      "toStatus": "PrescriptionGenerating",
      "triggerName": "RetryPrescriptionSync",
      "triggerType": "User",
      "requiredRole": "Physicist/System",
      "gateChecks": ["RetryAllowed"],
      "successActions": ["CreateOutboxPrescriptionSync"],
      "failureActions": ["StayInSyncFailed"],
      "workItemsToCreate": ["PrescriptionSync"],
      "configSlot": "S8ExceptionHandlingPolicy"
    },

    {
      "code": "QA-001",
      "phase": "QA",
      "description": "System automatically starts physics QA once plan and prescription are ready",
      "fromStatuses": ["PrescriptionReady"],
      "toStatus": "PlanQAInProgress",
      "triggerName": "StartQA",
      "triggerType": "System",
      "requiredRole": null,
      "gateChecks": ["PlanAndPrescriptionPresent"],
      "successActions": ["CreateQATask"],
      "failureActions": [],
      "workItemsToCreate": ["PlanQA"],
      "configSlot": null
    },
    {
      "code": "QA-002",
      "phase": "QA",
      "description": "Physicist or QA reviewer approves QA; optional double-check may follow per S5 policy",
      "fromStatuses": ["PlanQAInProgress"],
      "toStatus": "PlanQAApproved",
      "triggerName": "ApproveQA",
      "triggerType": "User",
      "requiredRole": "Physicist/QAReviewer",
      "gateChecks": ["QAFormValid"],
      "successActions": ["SaveQAReport"],
      "failureActions": ["RejectTransition"],
      "workItemsToCreate": ["PlanDoubleCheck"],
      "configSlot": "S5PlanDoubleCheck"
    },
    {
      "code": "QA-003",
      "phase": "QA",
      "description": "Physicist or QA reviewer rejects QA; case returns to planning or re-review",
      "fromStatuses": ["PlanQAInProgress"],
      "toStatus": "PlanQAFailed",
      "triggerName": "RejectQA",
      "triggerType": "User",
      "requiredRole": "Physicist/QAReviewer",
      "gateChecks": ["FailureReasonRequired"],
      "successActions": ["SaveQAFailure"],
      "failureActions": ["RejectTransition"],
      "workItemsToCreate": ["PlanDesign"],
      "configSlot": "S8ExceptionHandlingPolicy"
    },
    {
      "code": "QA-004",
      "phase": "QA",
      "description": "Physicist or system decides to rework the plan after a QA failure",
      "fromStatuses": ["PlanQAFailed"],
      "toStatus": "PlanningInProgress",
      "triggerName": "ReworkAfterQA",
      "triggerType": "User",
      "requiredRole": "Physicist/System",
      "gateChecks": ["ReworkDecisionMade"],
      "successActions": ["ReopenPlanningPath"],
      "failureActions": ["StayInQAFailed"],
      "workItemsToCreate": ["PlanDesign"],
      "configSlot": "S8ExceptionHandlingPolicy"
    },
    {
      "code": "QA-005",
      "phase": "QA",
      "description": "System starts optional independent double-check when S5 policy requires it",
      "fromStatuses": ["PlanQAApproved"],
      "toStatus": "PlanDoubleCheckOptional",
      "triggerName": "StartDoubleCheck",
      "triggerType": "System",
      "requiredRole": null,
      "gateChecks": ["S5DoubleCheckEnabled"],
      "successActions": ["CreateDoubleCheckTask"],
      "failureActions": ["SkipIfDisabled"],
      "workItemsToCreate": ["PlanDoubleCheck"],
      "configSlot": "S5PlanDoubleCheck"
    },
    {
      "code": "QA-006",
      "phase": "QA",
      "description": "System skips double-check when S5 policy has it disabled",
      "fromStatuses": ["PlanQAApproved"],
      "toStatus": "ReadyForScheduling",
      "triggerName": "SkipDoubleCheck",
      "triggerType": "System",
      "requiredRole": null,
      "gateChecks": ["S5DoubleCheckDisabled"],
      "successActions": ["Audit"],
      "failureActions": [],
      "workItemsToCreate": ["ScheduleSync"],
      "configSlot": "S5PlanDoubleCheck"
    },
    {
      "code": "QA-007",
      "phase": "QA",
      "description": "Senior physicist approves the independent double-check of the plan",
      "fromStatuses": ["PlanDoubleCheckOptional"],
      "toStatus": "ReadyForScheduling",
      "triggerName": "ApproveDoubleCheck",
      "triggerType": "User",
      "requiredRole": "SeniorPhysicist",
      "gateChecks": ["DoubleCheckApproved"],
      "successActions": ["CompleteDoubleCheckTask"],
