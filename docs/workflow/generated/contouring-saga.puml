@startuml
title Radiotherapy Workflow – Contouring Saga

hide empty description

skinparam DefaultFontName Arial
skinparam Shadowing false
skinparam ArrowColor #444444
skinparam state {
  BackgroundColor #F4F6F8
  BorderColor #5A6473
  FontSize 11
  ArrowFontSize 9
  ArrowColor #444444
}

[*] --> ARTStarted

state "1. Contouring" as CON {
  state AutoContouringRequested
  state AutoContouringInProgress
  state AutoContouringCompleted
  state ManualContouringInProgress
  state ManualContoursCompleted
  state ContoursReady
}

state PlanningPending #DDEEFF : « external »
state SimCompleted #DDEEFF : « external »

' ─── Transitions ─────────────────────────
ARTStarted --> AutoContouringRequested: CON-001 SubmitAutoContouringRequest[Sys]
AutoContouringRequested --> AutoContouringInProgress : CON-001 AutoContourProgressUpdated [Sys]
AutoContouringInProgress --> AutoContouringCompleted : CON-001 AutoContourProgressUpdated [Sys]
AutoContouringCompleted --> ManualContouringInProgress: CON-001 AutoContourProgressUpdated [Sys]
ManualContouringInProgress --> ManualContoursCompleted : CON-002 SubmitManualContourResult [User]\n«Physician»
ManualContoursCompleted --> ContoursReady: REV-001 ContourCompleted [Sys]
@enduml