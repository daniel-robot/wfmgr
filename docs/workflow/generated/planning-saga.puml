@startuml
title Radiotherapy Workflow – Planning Saga

hide empty description

skinparam DefaultFontName Arial
skinparam Shadowing false
skinparam ArrowColor #444444
skinparam state {
  BackgroundColor #F4F6F8
  BorderColor #5A6473
  FontSize 11
  ArrowFontSize 9
  ArrowColor #444444
}

[*] --> PlanningInProgress

state "5. Treatment Planning" as PLN {
  state PlanningInProgress
  state PlanReady
  state PlanUnderReview
  state PlanReviewed
  state ReadyForPromotion
}

' ─── Transitions ─────────────────────────
PlanningInProgress --> PlanReady : PLN-001 SubmitPlan [User]\n«Dosimetrist/Monaco»
PlanReady --> PlanUnderReview : PLN-002 StartPlanReview [User]\n«Physicist/Physician»
PlanUnderReview --> PlanReviewed : PLN-004 ApprovePlanReview [User]\n«Physicist/Physician»
PlanReviewed  --> ReadyForPromotion : PLN-004 MarkReady [User]\n«Physicist»
@enduml