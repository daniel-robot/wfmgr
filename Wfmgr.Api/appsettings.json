{
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200"
    ]
  },
  "ConnectionStrings": {
    "WfmgrDb": "Host=localhost;Port=5432;Database=WfmgrDb;Username=postgres;Password=postgres"
  },
  "PvMed": {
    "BaseUrl": "https://pvmed.local"
  },
  "Monaco": {
    "DropRoot": "/var/wfmgr/monaco-drop"
  },
  "RabbitMq": {
    "_comment": "Set Host to enable the message bus (e.g. 'localhost' for docker-compose). When unset, the outbox falls back to HTTP-only delivery and any Bus-mode action will fail fast.",
    "Host": "localhost",
    "Port": 5672,
    "VirtualHost": "/",
    "Username": "wfmgr",
    "Password": "wfmgr",
    "ManagementPort": 15672,
    "ManagementScheme": "http",
    "DeadLetterDegradedThreshold": 1,
    "DeadLetterUnhealthyThreshold": 100
  },
  "Messaging": {
    "_comment": "Outbox actions in BusActions are published to RabbitMQ instead of dispatched over HTTP. Requires RabbitMq:Host to be set.",
    "BusActions": []
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Authentication": {
    "Jwt": {
      "Issuer": "wfmgr",
      "Audience": "wfmgr-api",
      "TokenLifetimeHours": 8
    }
  },
  "AllowedHosts": "*"
}
